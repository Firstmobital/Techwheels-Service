{
  "name": "tw-scaffold",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 <21 || >=22.12.0 <23"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b --force && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "plans:autoupdate": "node scripts/plan_autoupdate.mjs",
    "plans:cleanup:retention": "node scripts/docs_plan_retention_cleanup.mjs",
    "docs:validate:plans": "node scripts/docs_plan_retention_validate.mjs",
    "docs:validate": "npm run docs:validate:plans",
    "docs:validate:ci": "npm run docs:validate:plans",
    "supabase:audit:cycle": "node scripts/supabase_audit_cycle.mjs",
    "supabase:audit:cycle:postdeploy": "node scripts/supabase_audit_cycle.mjs",
    "mobile:start": "npm --prefix ./mobile run start -- --tunnel",
    "mobile:start:clear": "npm --prefix ./mobile run start -- --clear --tunnel",
    "mobile:typecheck": "npm --prefix ./mobile run -s typecheck"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "papaparse": "^5.5.3",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "playwright": "^1.61.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9"
  }
}
