{
  "name": "techwheels-service-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:prod:android": "eas build -p android --profile production",
    "build:prod:apk": "eas build -p android --profile production-apk",
    "build:prod:ios": "eas build -p ios --profile production",
    "build:prod:ios:internal": "eas build -p ios --profile production-internal-ios",
    "build:preview:apk": "eas build -p android --profile preview",
    "build:preview:ios": "eas build -p ios --profile preview",
    "ota:prod:all": "CI=1 eas update --branch production --platform all --message",
    "ota:prod": "npm run ota:prod:all --",
    "ota:prod:ios": "CI=1 eas update --branch production --platform ios --message",
    "ota:preview": "CI=1 eas update --branch preview --platform all --message",
    "check:native-deps": "node scripts/check-native-deps.js",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
