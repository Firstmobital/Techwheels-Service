# Copy this file to .env.local and fill in real values.
# Never commit a file containing real secrets.

# --- Frontend (Vite, bundled into the client — see CONTRIBUTING.md) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_DEFAULT_DEALER_CODE=your-dealer-code
VITE_DEFAULT_DEALER_NAME="Your Dealer Name"

# --- Supabase project/management (server-side tooling only) ---
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_MANAGEMENT_TOKEN=your-management-api-token

# --- Database backup scripts (scripts/backup-metadata.sh, scripts/backup-full-db.sh) ---
# Server-side only. Do NOT prefix with VITE_ (must never reach the client bundle).
# Used to generate supabase/backups/full_metadata.sql and
# local_folder/backups/full_database.sql — see docs/shared/reference/DATABASE_TRUTH.md.
SUPABASE_DB_PASSWORD=your-db-password
#
# Full backup (scripts/backup-full-db.sh): set SUPABASE_PROJECT_REF and the script
# uses the direct connection db.<ref>.supabase.co (recommended — avoids pooler SSL drops).
# Metadata backup (scripts/backup-metadata.sh): pooler or direct both work.
SUPABASE_DB_HOST=your-pooler-host.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.your-project-ref
# BACKUP_USE_POOLER=1   # only if you must force pooler for full backup (less reliable)
